+function resolvePublicBaseUrl(): string {
+  const fromEnv = (process.env.APP_BASE_URL || process.env.BASE_URL || "").trim();
+  if (fromEnv) return fromEnv.replace(/\/$/, "");
+  return "http://localhost:5001";
